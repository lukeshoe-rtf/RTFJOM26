<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>JOM26 Shout Out</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: transparent;
      padding: 0 10px;  /* 10px side padding to match patch widget width */
    }

    .shoutout-widget {
      background: linear-gradient(135deg, #E65100, #F57C00);
      border-radius: 12px;
      padding: 0.8rem 1.2rem;
      color: white;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 0.15rem;
      min-height: 90px;
      overflow: hidden;
      box-shadow: 0 3px 12px rgba(230, 81, 0, 0.35);
    }

    .shoutout-header {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 1.8px;
      text-transform: uppercase;
      opacity: 0.85;
      margin-bottom: 0.1rem;
    }

    /* Name and type start invisible; JS animates them */
    .shoutout-name {
      font-size: 1rem;
      font-weight: 700;
      line-height: 1.3;
      opacity: 0;
      transform: translateY(8px);
      min-height: 1.3em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .shoutout-type {
      font-size: 0.68rem;
      font-weight: 500;
      opacity: 0;
      min-height: 1em;
      letter-spacing: 0.3px;
    }

    /* Shown when there are no entries yet */
    .shoutout-empty {
      font-size: 0.82rem;
      opacity: 0.65;
      font-style: italic;
      display: none;
    }
  </style>
</head>
<body>
  <div class="shoutout-widget">
    <div class="shoutout-header">📣 Shout Out!</div>
    <div class="shoutout-name" id="shoutout-name"></div>
    <div class="shoutout-type" id="shoutout-type"></div>
    <div class="shoutout-empty" id="shoutout-empty">Sign up as a school, organisation or community group to appear here!</div>
  </div>

  <script type="module" src="./shoutout-widget.js"></script>
</body>
</html>
